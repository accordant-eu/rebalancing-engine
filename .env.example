# --- Application Settings ---
# Used to seed the initial Superadmin user on fresh database boots
SUPERADMIN_EMAIL=admin@localhost
SUPERADMIN_PASSWORD=changeme123

# Alpaca paper trading credentials — required for --live alpaca mode
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Alpaca Broker API credentials — required for broker adapter
ALPACA_BROKER_API_KEY=
ALPACA_BROKER_API_SECRET=
ALERT_WEBHOOK_URL=
APCA_BROKER_URL=https://broker-api.sandbox.alpaca.markets/v1

# Logging
LOG_LEVEL=info

# Authentication
# Must be set to a secure random string in production (e.g. openssl rand -base64 32)
JWT_SECRET=
